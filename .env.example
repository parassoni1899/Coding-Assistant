# =============================================================================
# Codebase Assistant RAG — Environment Configuration
# Copy this file to .env and fill in values for your chosen environment.
# =============================================================================

# ENVIRONMENT: "local" | "cloud"
# Controls which provider implementations are loaded by the factory classes.
ENVIRONMENT=local

# =============================================================================
# TARGET REPOSITORY
# =============================================================================
TARGET_REPO_URL=https://github.com/pocketbase/pocketbase
# Local path where the repository will be cloned
TARGET_REPO_LOCAL_PATH=./data/repos/pocketbase

# =============================================================================
# LOCAL STACK (ENVIRONMENT=local)
# =============================================================================

# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model to use via Ollama for answer generation
# Recommended: qwen2.5-coder:7b  (4-bit quantized, ~4.7GB VRAM/RAM)
# Alternative:  llama3:8b          (4-bit quantized, ~4.8GB RAM)
LOCAL_LLM_MODEL=qwen2.5-coder:7b

# Embedding provider: "ollama" | "huggingface"
# - ollama: offloads embedding inference to the Ollama process (recommended)
# - huggingface: loads the model inside Python (faster for batch, uses ~1GB extra RAM)
LOCAL_EMBEDDING_PROVIDER=ollama

# Ollama embedding model (when LOCAL_EMBEDDING_PROVIDER=ollama)
# nomic-embed-text supports 8192 token context window — ideal for large Go functions
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# HuggingFace embedding model name (when LOCAL_EMBEDDING_PROVIDER=huggingface)
LOCAL_HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Local reranker model (cross-encoder, loaded by sentence-transformers on CPU)
# ~130MB download; very efficient on CPU
LOCAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =============================================================================
# VECTOR STORE
# =============================================================================

# Vector store backend: "chroma" | "qdrant" | "pinecone"
VECTOR_STORE=chroma

# ChromaDB persistence directory (used when VECTOR_STORE=chroma)
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=codebase_assistant

# Qdrant settings (used when VECTOR_STORE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=codebase_assistant

# =============================================================================
# RETRIEVAL SETTINGS
# =============================================================================

# Number of candidate chunks to retrieve before reranking
RETRIEVAL_TOP_K=20
# Number of final chunks passed to the LLM context after reranking
RERANK_TOP_M=5
# BM25 corpus index path (pickle file)
BM25_INDEX_PATH=./data/bm25_index.pkl

# =============================================================================
# AST GRAPH DATABASE
# =============================================================================
GRAPH_DB_PATH=./data/graph.db

# =============================================================================
# CLOUD STACK (ENVIRONMENT=cloud)
# =============================================================================

# LLM provider: "openai" | "anthropic" | "gemini"
CLOUD_LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_LLM_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-1.5-flash

# Cloud embedding provider: "openai" | "cohere"
CLOUD_EMBEDDING_PROVIDER=openai
COHERE_API_KEY=

# Pinecone settings (used when VECTOR_STORE=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=codebase-assistant
PINECONE_REGION=us-east-1

# Cloud reranker: "cohere"
CLOUD_RERANK_PROVIDER=cohere

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
